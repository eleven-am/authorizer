{
  "name": "@eleven-am/authorizer",
  "version": "1.0.1",
  "publishConfig": {
    "access": "public"
  },
  "author": "Roy OSSAI",
  "main": "./index.js",
  "types": "./index.d.ts",
  "license": "GPL-3.0",
  "scripts": {
    "test": "jest",
    "build": "rimraf dist && tsc",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "copy": "cp package.json dist && cp README.md dist && cp LICENSE dist && cp src/types.d.ts dist/index.d.ts",
    "push": "npm version patch && npm run copy && cd dist && npm publish && cd ..",
    "pipeline": "npm run build && npm run push"
  },
  "peerDependencies": {
    "@casl/ability": "^6.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "@casl/ability": {
      "optional": false
    },
    "@nestjs/common": {
      "optional": false
    },
    "@nestjs/core": {
      "optional": false
    }
  },
  "devDependencies": {
    "@casl/ability": "^6.7.3",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "jest": "^30.0.0",
    "prettier": "^3.5.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.0",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.3.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.test\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.d.ts",
      "!**/*.test.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
